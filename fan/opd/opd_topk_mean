#!/usr/bin/env bash

set -euo pipefail

export WANDB_PROJECT="${WANDB_PROJECT:-1.7b_base_capybara_sft247_opd_topk_mean}"
export WANDB_NAME="${WANDB_NAME:-2026_4_10_topk_mean}"
export REVERSE_KL_TOPK="${REVERSE_KL_TOPK:-8}"

# OPD baseline with old-student top-k reverse KL:
# - keeps the paper-style batching / sampling setup from opd_paper.sh
# - switches reverse_kl_estimator from "label" to "old_student_topk_mean"
# - uses REVERSE_KL_TOPK to control the top-k size

accelerate launch \
  --config_file /apdcephfs_qy4/share_302593112/shaofanliu/projects/lzh/trl/examples/accelerate_configs/deepspeed_zero3.yaml \
  opd.py \
  --model_name_or_path /apdcephfs_qy4_302593112/share_302593112/shaofanliu/projects/lzh/trl/fan/SFT/output_qwen3_1_7base_capybara/checkpoint-247 \
  --tokenizer_name_or_path Qwen/Qwen3-1.7B \
  --teacher_model_name_or_path Qwen/Qwen3-8B \
  --dataset_name qwedsacf/competition_math \
  --dataset_train_split train \
  --dataset_eval_split none \
  --enable_thinking false \
  --output_dir outputs/opd-qwen3_1_7base_capybarasft-from-8b-topk-mean-k${REVERSE_KL_TOPK} \
  --learning_rate 3e-6 \
  --lr_scheduler_type cosine \
  --num_train_epochs 3 \
  --groups_per_batch 128 \
  --group_size 1 \
  --tinker_single_update false \
  --per_device_train_batch_size 4 \
  --gradient_accumulation_steps 1 \
  --max_completion_length 4096 \
  --temperature 1.0 \
  --top_p 1.0 \
  --logging_steps 1 \
  --save_strategy steps \
  --save_steps 100 \
  --save_total_limit 20 \
  --eval_strategy no \
  --report_to wandb \
  --bf16 true \
  --gradient_checkpointing \
  --dtype bfloat16 \
  --reverse_kl_estimator old_student_topk_mean \
  --reverse_kl_topk "${REVERSE_KL_TOPK}"
